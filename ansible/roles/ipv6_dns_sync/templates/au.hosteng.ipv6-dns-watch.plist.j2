<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>au.hosteng.ipv6-dns-watch</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{ ipv6_venv_path }}/bin/python3</string>
        <string>/usr/local/bin/ipv6_dns_watch_macos.py</string>
    </array>

    <!-- Run once at load, then keep running to watch for changes -->
    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/var/log/ipv6_dns_watch.out.log</string>

    <key>StandardErrorPath</key>
    <string>/var/log/ipv6_dns_watch.err.log</string>

    <!-- Give the watcher enough time to complete DNS cleanup on shutdown
         before launchd forcibly kills it. The cleanup runs nsupdate which
         needs a moment to connect to the DNS server.
         Must be longer than the timeout in run_shutdown() (25s). -->
    <key>ExitTimeout</key>
    <integer>30</integer>

    <!-- Run at low priority so normal work is not affected -->
    <key>Nice</key>
    <integer>10</integer>

    <!-- ProcessType Background tells launchd this is a background service.
         This affects shutdown ordering — Background services are stopped
         before the network is torn down, giving us time to reach the DNS
         server during cleanup. -->
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
